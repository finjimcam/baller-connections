# Copy to .env and adjust. Never commit .env.

# Seed for deterministic daily puzzle selection — set once, then never change,
# or past daily puzzles will shift.
DAILY_SALT=change-me

# Politeness throttle toward the self-hosted transfermarkt-api scraper
# (seconds between ALL outbound API requests).
TM_MIN_REQUEST_INTERVAL=2.5

# Ingest scope config. Swap to competitions.dev.yml for a small test seed.
INGEST_CONFIG=/app/app/ingest/config/competitions.yml

# UTC hour for the daily refresh + puzzle pre-warm job.
DAILY_REFRESH_HOUR_UTC=4
